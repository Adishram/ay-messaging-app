{
  "name": "ay-facetime",
  "version": "1.0.6",
  "description": "FaceTime-like video calling & messaging app for macOS & Windows",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "make": "electron-forge make",
    "dist": "electron-builder build --mac --win --x64 --arm64",
    "publish": "electron-builder build --mac --win --x64 --arm64 --publish always"
  },
  "build": {
    "appId": "com.adishram.aymessaging",
    "productName": "A&Y",
    "executableName": "ay-facetime",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Adishram",
        "repo": "ay-messaging-app"
      }
    ],
    "files": [
      "src/**/*",
      "package.json",
      "assets/**/*",
      "!dist",
      "!ay-website",
      "!out"
    ],
    "mac": {
      "category": "public.app-category.social-networking",
      "target": [
        "dmg",
        "zip"
      ],
      "identity": null,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "extendInfo": {
        "NSCameraUsageDescription": "A&Y needs camera access for video calls.",
        "NSMicrophoneUsageDescription": "A&Y needs microphone access for video and audio calls."
      }
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.png",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "runAfterFinish": true
    }
  },
  "keywords": [
    "electron",
    "video-call",
    "messaging",
    "webrtc"
  ],
  "author": "A&Y",
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.6.0",
    "@electron-forge/maker-dmg": "^7.6.0",
    "@electron-forge/maker-zip": "^7.6.0",
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "b4a": "^1.6.6",
    "electron-updater": "^6.8.3",
    "hypercore-crypto": "^3.4.2",
    "hyperswarm": "^4.17.0",
    "simple-peer": "^9.11.1"
  },
  "overrides": {
    "tar": "^7.5.11"
  }
}
